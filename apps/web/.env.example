# Public site URL (canonical, OG, sitemap) — e.g. https://drivescore.club
NEXT_PUBLIC_SITE_URL=

# PostHog (client) — optional locally
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog (server) — unique visitor marquee; falls back to static count if unset
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=

# Resend waitlist — see docs/06-waitlist-and-email.md
RESEND_API_KEY=
# Resend Segment ID (Audiences were renamed to Segments)
RESEND_AUDIENCE_ID=
# Verified sender, e.g. DriveScore <hello@drivescore.club>
# Local-only test: DriveScore <onboarding@resend.dev> (account email only)
RESEND_FROM_EMAIL=
